# MODULE.bazel.local — Machine-specific DPDK configuration
# Copy this file to MODULE.bazel.local and adjust the path for your machine.
# MODULE.bazel.local is gitignored and won't be committed.
#
# The "path" should point to your DPDK installation root, where:
#   {path}/include/  contains DPDK headers (rte_mbuf.h, etc.)
#   {path}/lib/      contains DPDK shared libraries (librte_eal.so, etc.)
#
# If your libs are in a subdirectory (e.g. lib/aarch64-linux-gnu/),
# you may need to add that path to /etc/ld.so.conf.d/ and run ldconfig,
# or add a -L flag in third_party/dpdk.BUILD.

new_local_repository = use_repo_rule("@bazel_tools//tools/build_defs/repo:local.bzl", "new_local_repository")

# Example: DPDK installed system-wide at /usr/local
new_local_repository(
    name = "dpdk",
    path = "/usr/local",
    build_file = "third_party/dpdk.BUILD",
)

# Example: DPDK at a custom location
# new_local_repository(
#     name = "dpdk",
#     path = "/opt/xsl-dpdk",
#     build_file = "third_party/dpdk.BUILD",
# )
