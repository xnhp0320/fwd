# MODULE.bazel.local.example
# Copy this to MODULE.bazel.local and customize for your machine
# MODULE.bazel.local is gitignored and won't be committed

# For DPDK at /usr/local with aarch64 libs (current machine):
# No MODULE.bazel.local needed - this is the default in MODULE.bazel

# For DPDK at a custom location, uncomment and modify:
# new_local_repository = use_repo_rule("@bazel_tools//tools/build_defs/repo:local.bzl", "new_local_repository")
# 
# new_local_repository(
#     name = "dpdk",
#     path = "/opt/dpdk-23.11",  # Change to your DPDK installation path
#     build_file = "dpdk_custom.BUILD",  # Use a custom BUILD file with your lib path
# )

# Then create dpdk_custom.BUILD with your specific lib directory:
# load("@rules_cc//cc:defs.bzl", "cc_library")
# 
# cc_library(
#     name = "dpdk",
#     hdrs = glob(["include/**/*.h"]),
#     includes = ["include"],
#     linkopts = [
#         "-L/opt/dpdk-23.11/lib/x86_64-linux-gnu",  # Your custom lib path
#         "-Wl,--as-needed",
#         "-lrte_node",
#         # ... (copy all the -lrte_* flags from dpdk/BUILD.bazel)
#     ],
#     copts = ["-include rte_config.h"],
#     visibility = ["//visibility:public"],
# )
